# MedGemma Explica - Backend Configuration
# All variables use the MEDGEMMA_ prefix (see config.py)

# Google Cloud project for Gemini Flash, GCS, Firestore
MEDGEMMA_PROJECT_ID=your-project-id
MEDGEMMA_LOCATION=us-central1

# GCS bucket for X-ray image uploads
MEDGEMMA_GCS_BUCKET=your-project-medgemma-explica

# Firestore collection name
MEDGEMMA_FIRESTORE_COLLECTION=analyses

# MedGemma endpoint (Vertex AI)
MEDGEMMA_MEDGEMMA_ENDPOINT_URL=https://your-endpoint.us-central1-123456.prediction.vertexai.goog
MEDGEMMA_MEDGEMMA_ENDPOINT_PROJECT=123456789
MEDGEMMA_MEDGEMMA_ENDPOINT_ID=your-endpoint-id

# Gemini Flash model
MEDGEMMA_GEMINI_MODEL=gemini-3-flash-preview
MEDGEMMA_GEMINI_LOCATION=global

# Cloud Healthcare API - DICOM store for CT scans
# For testing with IDC public data, use hai-cd3-foundations defaults.
# For your own DICOM store, set these to your project.
MEDGEMMA_DICOM_PROJECT=your-project-id
MEDGEMMA_DICOM_LOCATION=us-central1
MEDGEMMA_DICOM_DATASET=your-dicom-dataset
MEDGEMMA_DICOM_STORE=your-dicom-store

# CORS
MEDGEMMA_FRONTEND_URL=http://localhost:3000
